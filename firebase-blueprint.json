{
  "entities": {
    "RecentDestination": {
      "title": "Recent Destination",
      "description": "A destination visited by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "timestamp": { "type": "number" },
        "count": { "type": "number" },
        "hours": { "type": "array", "items": { "type": "integer" } }
      },
      "required": ["id", "name", "lat", "lng", "timestamp", "count"]
    },
    "SavedRoute": {
      "title": "Saved Route",
      "description": "A named sequence of destinations.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "destinations": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" },
              "name": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "destinations", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a user including their preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." },
        "settings": {
          "type": "object",
          "properties": {
            "radius": { "type": "number" },
            "transportMode": { "type": "string", "enum": ["car", "bus", "train"] },
            "vibrationEnabled": { "type": "boolean" },
            "selectedSound": { "type": "string" },
            "autoCenter": { "type": "boolean" },
            "isMuted": { "type": "boolean" },
            "trackingMode": { "type": "string", "enum": ["high", "balanced", "low", "eco"] }
          }
        }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles stored by their UID."
    },
    "/users/{userId}/history/{destId}": {
      "schema": "RecentDestination",
      "description": "History of destinations for a specific user."
    },
    "/users/{userId}/routes/{routeId}": {
      "schema": "SavedRoute",
      "description": "Saved named routes for a specific user."
    }
  }
}
